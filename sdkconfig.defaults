CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1
CONFIG_BT_NIMBLE_ATT_PREFERRED_MTU=247

CONFIG_RNDL_GPIO=10
CONFIG_RNDL_ROWS=16
CONFIG_RNDL_COLS=16

# Eternaglo Pico: relay on GPIO 1, active high. Data on GPIO 10, button on GPIO 9.
CONFIG_RNDL_RELAY_GPIO=1
CONFIG_RNDL_RELAY_ACTIVE_LOW=n
CONFIG_RNDL_BUTTON_GPIO=9
